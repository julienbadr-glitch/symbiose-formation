<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Symbiose — Formation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            display: flex;
            background: linear-gradient(135deg, #0a0e27 0%, #141b3d 30%, #1a2350 50%, #0f1535 100%);
            color: #fff;
            overflow: hidden;
        }

        /* Left side — branding */
        .brand-side {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            position: relative;
        }

        .brand-side::before {
            content: '';
            position: absolute;
            top: -20%;
            left: -20%;
            width: 60%;
            height: 60%;
            background: radial-gradient(circle, rgba(56, 97, 251, 0.12) 0%, transparent 70%);
            pointer-events: none;
        }

        .brand-side::after {
            content: '';
            position: absolute;
            bottom: -10%;
            right: -10%;
            width: 50%;
            height: 50%;
            background: radial-gradient(circle, rgba(99, 132, 255, 0.08) 0%, transparent 70%);
            pointer-events: none;
        }

        .brand-content {
            max-width: 480px;
            position: relative;
            z-index: 1;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 3rem;
        }

        .logo img {
            height: 52px;
            width: auto;
        }

        .brand-title {
            font-size: 3rem;
            font-weight: 700;
            line-height: 1.15;
            letter-spacing: -1.5px;
            margin-bottom: 1.5rem;
        }

        .brand-title span {
            background: linear-gradient(135deg, #6384ff, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .brand-subtitle {
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.55);
            line-height: 1.7;
            font-weight: 400;
        }

        .features {
            display: flex;
            gap: 2rem;
            margin-top: 3rem;
        }

        .feature {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.5);
        }

        .feature-icon {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: rgba(56, 97, 251, 0.15);
            border: 1px solid rgba(56, 97, 251, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: #6384ff;
            flex-shrink: 0;
        }

        /* Right side — login form */
        .login-side {
            width: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem;
        }

        .login-card {
            width: 100%;
            max-width: 400px;
            background: rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 2.5rem;
        }

        .login-card h2 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            letter-spacing: -0.3px;
        }

        .login-card p {
            color: rgba(255, 255, 255, 0.45);
            font-size: 0.9rem;
            margin-bottom: 2rem;
            line-height: 1.5;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            font-size: 0.8rem;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.6);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group input {
            width: 100%;
            padding: 14px 16px;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: #fff;
            font-size: 1rem;
            font-family: inherit;
            outline: none;
            transition: all 0.25s ease;
        }

        .form-group input::placeholder {
            color: rgba(255, 255, 255, 0.25);
        }

        .form-group input:focus {
            border-color: #3861fb;
            background: rgba(56, 97, 251, 0.08);
            box-shadow: 0 0 0 3px rgba(56, 97, 251, 0.15);
        }

        .login-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #3861fb 0%, #6384ff 100%);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .login-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 30px rgba(56, 97, 251, 0.4);
        }

        .login-btn:active {
            transform: translateY(0);
        }

        .login-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .login-btn .spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
            margin: 0 auto;
        }

        .login-btn.loading .btn-text { display: none; }
        .login-btn.loading .spinner { display: block; }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .error-msg {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #fca5a5;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 0.85rem;
            margin-bottom: 1.5rem;
            display: none;
            line-height: 1.4;
        }

        .error-msg.visible { display: block; }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.5rem 0;
            color: rgba(255, 255, 255, 0.2);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255, 255, 255, 0.08);
        }

        .footer-note {
            text-align: center;
            color: rgba(255, 255, 255, 0.25);
            font-size: 0.75rem;
            margin-top: 1.5rem;
            line-height: 1.5;
        }

        /* Floating particles */
        .particles {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(99, 132, 255, 0.2);
            border-radius: 50%;
            animation: float linear infinite;
        }

        @keyframes float {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-10vh) rotate(720deg); opacity: 0; }
        }

        /* Responsive */
        @media (max-width: 960px) {
            body { flex-direction: column; overflow-y: auto; }
            .brand-side { padding: 2rem; min-height: auto; }
            .brand-title { font-size: 2rem; }
            .login-side { width: 100%; padding: 2rem; }
            .features { display: none; }
        }

        @media (max-width: 480px) {
            .login-card { padding: 1.5rem; }
            .brand-side { padding: 1.5rem; }
            .brand-title { font-size: 1.6rem; }
        }
    </style>
</head>
<body>
    <!-- Floating particles -->
    <div class="particles" id="particles"></div>

    <!-- Left — Branding -->
    <div class="brand-side">
        <div class="brand-content">
            <div class="logo">
                <img src="assets/logo_symbiose_blanc.png" alt="Symbiose">
            </div>
            <h1 class="brand-title">
                Devenez expert<br>
                <span>de votre outil RH.</span>
            </h1>
            <p class="brand-subtitle">
                La plateforme de formation interactive pour maitriser
                Symbiose et transformer la gestion de vos ressources humaines.
            </p>
            <div class="features">
                <div class="feature">
                    <div class="feature-icon">&#10003;</div>
                    8 modules
                </div>
                <div class="feature">
                    <div class="feature-icon">&#10003;</div>
                    Jeux de role
                </div>
                <div class="feature">
                    <div class="feature-icon">&#10003;</div>
                    Certification
                </div>
            </div>
        </div>
    </div>

    <!-- Right — Login Form -->
    <div class="login-side">
        <div class="login-card">
            <h2>Bienvenue</h2>
            <p>Entrez votre adresse email professionnelle pour acceder a votre formation.</p>

            <div class="error-msg" id="errorMsg"></div>

            <form id="loginForm" autocomplete="on">
                <div class="form-group">
                    <label for="email">Adresse email</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="prenom.nom@mercato-emploi.com"
                        required
                        autocomplete="email"
                        autofocus
                    >
                </div>

                <button type="submit" class="login-btn" id="loginBtn">
                    <span class="btn-text">Acceder a ma formation</span>
                    <div class="spinner"></div>
                </button>
            </form>

            <div class="divider">Espace reserve</div>

            <p class="footer-note">
                Cette plateforme est reservee aux collaborateurs<br>
                du reseau Mercato de l'Emploi.
            </p>
        </div>
    </div>

    <script>
        // Particles
        (function() {
            const container = document.getElementById('particles');
            for (let i = 0; i < 20; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                p.style.left = Math.random() * 100 + '%';
                p.style.animationDuration = (15 + Math.random() * 25) + 's';
                p.style.animationDelay = (-Math.random() * 30) + 's';
                p.style.width = p.style.height = (2 + Math.random() * 4) + 'px';
                container.appendChild(p);
            }
        })();

        // Login
        const form = document.getElementById('loginForm');
        const btn = document.getElementById('loginBtn');
        const errorEl = document.getElementById('errorMsg');
        const emailInput = document.getElementById('email');

        // Check existing session
        (function checkSession() {
            const session = localStorage.getItem('symbiose_session');
            if (session) {
                try {
                    const data = JSON.parse(session);
                    if (data && data.token) {
                        // Validate token with server
                        fetch('api/state.php', {
                            method: 'GET',
                            headers: { 'Authorization': 'Bearer ' + data.token }
                        })
                        .then(r => r.json())
                        .then(d => {
                            if (d.success) {
                                window.location.href = 'index.html';
                            }
                        })
                        .catch(() => {});
                    }
                } catch(e) {}
            }
        })();

        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            const email = emailInput.value.trim().toLowerCase();
            if (!email) return;

            btn.classList.add('loading');
            btn.disabled = true;
            errorEl.classList.remove('visible');

            try {
                const res = await fetch('api/login.php', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email })
                });

                const data = await res.json();

                if (!res.ok || !data.success) {
                    throw new Error(data.error || 'Adresse non autorisee');
                }

                // Save session
                localStorage.setItem('symbiose_session', JSON.stringify({
                    email: data.user.email,
                    token: data.token, isAdmin: data.isAdmin || false
                }));

                if (data.state) {
                    localStorage.setItem('symbiose_state', JSON.stringify(data.state));
                }

                // Redirect to dashboard
                window.location.href = 'index.html';

            } catch (err) {
                errorEl.textContent = err.message || 'Erreur de connexion. Reessayez.';
                errorEl.classList.add('visible');
                btn.classList.remove('loading');
                btn.disabled = false;
                emailInput.focus();
            }
        });
    </script>
<script>
(async function spiderSSOCheck(){
    var SA="https://backend.prod.spider.mercato-emploi.com/api/formation/logged-user";
    try{
        var r=await fetch(SA,{method:"GET",credentials:"include",headers:{"Accept":"application/json"}});
        if(!r.ok)return;
        var su=await r.json();
        if(su.error||!su.email)return;
        var lr=await fetch("/api/spider-login.php",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({email:su.email,firstname:su.firstname,lastname:su.lastname,profilePicture:su.profilePicture||null})});
        var d=await lr.json();
        if(!lr.ok||!d.success)return;
        localStorage.setItem("symbiose_session",JSON.stringify({email:d.user.email,token:d.token,isAdmin:d.isAdmin||false}));
        if(d.state){localStorage.setItem("symbiose_state",JSON.stringify(d.state));}
        window.location.href="/index.html";
    }catch(e){console.log("Spider SSO not available on login:",e.message);}
})();
</script>
</body>
</html>
